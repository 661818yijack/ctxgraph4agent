# ─── API Relation Extraction (Tier 2) ────────────────────────────
# Set CTXGRAPH_API_KEY to enable API-based relation augmentation.
# Supports OpenAI-compatible and Anthropic endpoints.
CTXGRAPH_API_KEY=
CTXGRAPH_API_URL=              # default: auto-detected from model name
CTXGRAPH_API_MODEL=            # default: gpt-4.1-mini (OpenAI) or claude-haiku-4-5-20251001 (Anthropic)

# ─── Ollama Relation Extraction (Tier 3) ─────────────────────────
CTXGRAPH_OLLAMA_URL=           # default: http://localhost:11434
CTXGRAPH_OLLAMA_MODEL=         # default: qwen2.5:7b

# ─── Tier Toggles ────────────────────────────────────────────────
# Set to "1" to disable a tier
# CTXGRAPH_NO_API=1
# CTXGRAPH_NO_OLLAMA=1

# ─── OpenRouter (for benchmarking open-source models) ────────────
OPENROUTER_API_KEY=            # for scripts/benchmark_openrouter.py

# ─── Experimental ────────────────────────────────────────────────
# CTXGRAPH_RELEX=1             # enable experimental relex ONNX engine

# ─── MCP / Embedding ─────────────────────────────────────────────
CTXGRAPH_DB=                   # path to database file
# CTXGRAPH_NO_EMBED=1          # disable embedding

# ─── Models ──────────────────────────────────────────────────────
CTXGRAPH_MODELS_DIR=           # default: ~/.cache/ctxgraph/models
